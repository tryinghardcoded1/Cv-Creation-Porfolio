{
  "entities": {
    "ContactMessage": {
      "title": "ContactMessage",
      "description": "A message submitted from the contact form",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["name", "email", "message", "createdAt"]
    }
  },
  "firestore": {
    "/messages/{messageId}": {
      "schema": { "$ref": "#/entities/ContactMessage" },
      "description": "Stores contact form submissions"
    }
  }
}
