rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function incoming() { return request.resource.data; }

    function isValidMessage(data) {
      return data.keys().hasAll(['name', 'email', 'message', 'createdAt'])
        && data.keys().size() == 4
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.size() > 5 && data.email.size() <= 150
        && data.message is string && data.message.size() > 0 && data.message.size() <= 2000
        && data.createdAt == request.time;
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /messages/{messageId} {
      // Allow anybody to create a message (public contact form)
      allow create: if isValidId(messageId) && isValidMessage(incoming());
      // Only the app owner (admin) should read them, or no one from client side if not needed.
      allow read, update, delete: if false;
    }
  }
}
